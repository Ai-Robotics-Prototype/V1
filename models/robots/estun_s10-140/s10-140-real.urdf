<?xml version="1.0" encoding="UTF-8"?>
<!--
  Estun S10-140 - REAL MESHES on computed joint pivots
  Pipeline: assembly GLB world positions -> joint pivots from link overlaps ->
  meshes rebased about their joints -> decimated to 18.3k tris (tablet-safe).
  Zero pose = the SolidWorks export pose (L-shape, wrist twisted).
  Coordinate frame: Y-UP (matches the GLB/three.js frame; no rotation needed in viewer).
  Joint axes J5/J6 reflect the posed wrist orientation (computed from geometry).
  Exact DH refinement comes from the teach pendant table when the robot arrives.
-->
<robot name="estun_s10_140_real">
  <link name="world"/>
  <joint name="world_joint" type="fixed"><parent link="world"/><child link="base_link"/><origin xyz="0 0 0" rpy="0 0 0"/></joint>
  <link name="base_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link0_base.glb"/></geometry>
    </visual>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0.00000 0.07360 0.00000" rpy="0 0 0"/>
    <axis xyz="0.0000 1.0000 0.0000"/>
    <limit lower="-6.2832" upper="6.2832" effort="150" velocity="2.618"/>
  </joint>
  <link name="link_1">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link1_shoulder.glb"/></geometry>
    </visual>
  </link>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0.03459 0.10991 0.07176" rpy="0 0 0"/>
    <axis xyz="0.0000 0.0000 1.0000"/>
    <limit lower="-6.2832" upper="6.2832" effort="150" velocity="2.618"/>
  </joint>
  <link name="link_2">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link2_upper_arm.glb"/></geometry>
    </visual>
  </link>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0.24885 0.63230 -0.03979" rpy="0 0 0"/>
    <axis xyz="0.0000 0.0000 1.0000"/>
    <limit lower="-2.7925" upper="2.7925" effort="150" velocity="2.618"/>
  </joint>
  <link name="link_3">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link3_forearm.glb"/></geometry>
    </visual>
  </link>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin xyz="0.51027 -0.01934 -0.10011" rpy="0 0 0"/>
    <axis xyz="1.0000 0.0000 0.0000"/>
    <limit lower="-6.2832" upper="6.2832" effort="150" velocity="3.1416"/>
  </joint>
  <link name="link_4">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link4_wrist1.glb"/></geometry>
    </visual>
  </link>
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/><child link="link_5"/>
    <origin xyz="0.10384 0.01391 0.00000" rpy="0 0 0"/>
    <axis xyz="0.0000 -0.9019 0.4319"/>
    <limit lower="-6.2832" upper="6.2832" effort="150" velocity="3.1416"/>
  </joint>
  <link name="link_5">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link5_wrist2.glb"/></geometry>
    </visual>
  </link>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/><child link="link_6"/>
    <origin xyz="0.08118 0.05552 0.05191" rpy="0 0 0"/>
    <axis xyz="0.0545 0.4313 0.9006"/>
    <limit lower="-6.2832" upper="6.2832" effort="150" velocity="3.1416"/>
  </joint>
  <link name="link_6">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="links/final_link6_flange.glb"/></geometry>
    </visual>
  </link>
</robot>