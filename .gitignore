build/
install/
log/
*.pyc
__pycache__/
*.engine
*.onnx
*.gguf
*.pt
.claude/

# Large Isaac ROS quickstart assets (e.g. 1.6 GB visual_slam rosbag) — not source
isaac_ros_assets/
# Generated frontend build output (produced by `npm run build`)
src/cobot_dashboard/mock_server/static/

# Third-party Livox driver + SDK — cloned and configured by
# scripts/install_livox.sh, not vendored in this repo.
src/Livox-SDK2/
src/livox_ros_driver2/

# Ad-hoc backups of robot 3D assets (~90 MB of .glb) — restore from
# models/robots/estun_s10-140/links/ instead, the live set is the source.
models/robots/estun_s10-140/links.bak/

# Raw robot telemetry captures + DH-fit derived scratch. Calibration
# checkpoints worth keeping live under config/ (e.g. dh_fit_report.txt);
# everything else in data/ is regenerable capture.
data/

# Timestamped URDF backups from scripts/fit_dh.py — regeneratable.
*.urdf.bak-*

# Ad-hoc WS frame captures at the repo root (posture.py fallback path
# when /opt/cobot/logs isn't writable). Only match at the top level so
# real data JSONL under packages is unaffected.
/*.jsonl

# Uncompressed source meshes — the compressed set in
# models/robots/estun_s10-140/links/ is the versioned copy.
models/robots/estun_s10-140/links.uncompressed/

# DH-fit tool output URDF — derived from config/dh_fit_report.txt.
config/estun_s10_140_fitted.urdf

# Secrets / env files — never commit. Belt-and-braces; nothing matches today.
.env
.env.*
*.pem
*.key
**/credentials.json
