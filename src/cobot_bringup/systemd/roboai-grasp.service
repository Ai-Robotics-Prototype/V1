[Unit]
Description=RoboAi Grasp Planner
After=roboai-depth-segment.service
Wants=roboai-depth-segment.service

[Service]
Type=simple
User=teddy
WorkingDirectory=/home/teddy/cobot_ws
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && source /home/teddy/cobot_ws/install/setup.bash && ros2 run object_detection grasp_planner'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
