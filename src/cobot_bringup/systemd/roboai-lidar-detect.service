[Unit]
Description=RoboAi LiDAR-Primary 3D Object Detector
After=roboai-accumulator.service
Wants=roboai-accumulator.service

[Service]
Type=simple
User=teddy
WorkingDirectory=/home/teddy/cobot_ws
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && source /home/teddy/cobot_ws/install/setup.bash && ros2 run object_detection lidar_detector_node'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
