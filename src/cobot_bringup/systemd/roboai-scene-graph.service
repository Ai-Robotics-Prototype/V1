[Unit]
Description=RoboAi Scene Graph Tracker
After=roboai-lidar-detect.service roboai-depth-segment.service
Wants=roboai-lidar-detect.service

[Service]
Type=simple
User=teddy
WorkingDirectory=/home/teddy/cobot_ws
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && source /home/teddy/cobot_ws/install/setup.bash && ros2 run scene_graph scene_graph_node'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
