# Example EnvironmentFile for roboai-estun.service.
# Deploy with:
#   sudo install -o root -g root -m 0644 \
#       src/cobot_bringup/systemd/roboai-estun.env.example \
#       /etc/default/roboai-estun
# and then:
#   sudo systemctl daemon-reload
#   sudo systemctl restart roboai-estun
# (do NOT restart while the robot is powered on and the operator is
# out of the cell.)

# Override the driver's target address. Any value here wins over the
# YAML default in src/estun_driver/config/estun.yaml.
# Current cell (Norse robot subnet):
# ESTUN_ROBOT_IP=192.168.2.136
# ESTUN_ROBOT_PORT=9000
