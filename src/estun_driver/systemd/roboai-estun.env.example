# /etc/default/roboai-estun — env-file drop-in read by
# roboai-estun.service (EnvironmentFile=-/etc/default/roboai-estun).
# Copy this file to /etc/default/roboai-estun and edit for the cell.
#
# All variables are OPTIONAL. If a variable is absent, the driver
# falls back to the ROS parameter default from config/estun.yaml.
#
# ── Robot network (per-cell override) ───────────────────────────
# Point at the specific arm on this cell's subnet.
#ESTUN_ROBOT_IP=192.168.2.136
#ESTUN_ROBOT_PORT=9000
#
# ── Safety gates ─────────────────────────────────────────────────
# BOTH gates must be OPEN for /robot/jog_command to emit Robot/jog
# frames on the wire. Every gate defaults to CLOSED in the YAML, so
# the ONLY way motion happens is if this env file is present AND
# both flags are set to 1/true here. A fresh install with no env
# file runs the driver as a read-only telemetry mirror.
#
# ESTUN_MONITOR_ONLY=false     # false → motion gate one is OPEN
# ESTUN_ALLOW_JOG=1            # 1     → motion gate two is OPEN
#
# Cartesian jog is a SEPARATE, independently-gated write path. Do not
# enable it without a bench test at the current jog_speed_cap.
# ESTUN_ALLOW_CARTESIAN=1
#
# Power write path — the driver publishes Robot/switchOn (enable),
# Robot/switchOff (disable), System/ClearError (clear alarm) when
# this is set. Nothing in the driver auto-enables; every enable
# comes from an explicit operator gesture on /robot/power_command.
# ESTUN_ALLOW_POWER=1
#
# ── Session ops recap ────────────────────────────────────────────
#   1. Drop this file into /etc/default/roboai-estun.
#   2. Set the flags you want for the session.
#   3. `sudo systemctl start roboai-estun`
#   4. Do the work.
#   5. `sudo systemctl stop roboai-estun`
# The unit stays `disabled` at boot on purpose — start/stop is
# manual, per-session.
